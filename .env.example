# ─── Board identity ────────────────────────────────────────
# Name of the person being celebrated (shown in the header)
NEXT_PUBLIC_PERSON_NAME=

# Your team name (shown in the header subtitle)
NEXT_PUBLIC_TEAM_NAME=

# Occasion date (ISO 8601) — the board locks and occasion-day confetti fires on this day
NEXT_PUBLIC_OCCASION_DATE=2026-12-31T23:59:59Z

# Occasion type — farewell | birthday | anniversary | custom
NEXT_PUBLIC_OCCASION_TYPE=farewell

# Optional — override the auto-generated board title
# NEXT_PUBLIC_BOARD_TITLE=

# ─── Theme ─────────────────────────────────────────────────
# Set to "dark" for the dark mode UI; omit or "light" for the default light UI
# NEXT_PUBLIC_UI_VARIANT=dark

# ─── GIF search (optional) ────────────────────────────────
# Get a free API key at https://developers.giphy.com/
GIPHY_API_KEY=

# ─── Database and storage ─────────────────────────────────
# Neon Postgres connection string (from https://neon.tech dashboard)
# DATABASE_URL=postgres://...

# Vercel Blob token (set automatically when you link Vercel Blob)
# BLOB_READ_WRITE_TOKEN=
